{
  "name": "solar-earth-watch",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "Live solar-event witness dashboard from Sun to Earth.",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
